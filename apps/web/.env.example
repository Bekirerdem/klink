# Klink frontend env template
# Copy to .env.local and fill values

# Privy embedded wallet — müşteri tarafının cüzdansız akışı için
# https://dashboard.privy.io → app yarat → app id kopyala
NEXT_PUBLIC_PRIVY_APP_ID=

# WalletConnect Cloud project id (mekan/staff/dev MetaMask flow için)
# https://cloud.walletconnect.com — 2 dakika
NEXT_PUBLIC_WC_PROJECT_ID=

# Monad testnet
NEXT_PUBLIC_MONAD_CHAIN_ID=10143
NEXT_PUBLIC_MONAD_RPC_URL=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_MONAD_EXPLORER_URL=https://testnet.monadexplorer.com

# Deployed contract addresses (fill after `forge script` deploy)
NEXT_PUBLIC_PAY_BILL_ADDRESS=
NEXT_PUBLIC_TIP_POOL_ADDRESS=
NEXT_PUBLIC_LOYALTY_NFT_ADDRESS=
NEXT_PUBLIC_MOCK_USDC_ADDRESS=

# Optional analytics
NEXT_PUBLIC_ANALYTICS_ID=
