# Klink contract deploy env template
# Copy to .env and fill values (NEVER commit .env)

# Wallet used for deploys (use a fresh hot wallet, not your main one)
DEPLOYER_PRIVATE_KEY=

# Monad testnet RPC + explorer
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_API_KEY=

# Optional: initial merchant + staff addresses for seed script
SEED_MERCHANT_ADDRESS=
SEED_STAFF_ADDRESSES=
